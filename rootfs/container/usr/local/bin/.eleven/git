#!/bin/sh
  FN=$(echo "${1}" | tr '[:upper:]' '[:lower:]')
  shift

  case "${FN}" in
    "slice")
      GITHUB_REPO=$(echo "https://github.com/${1}" | sed 's|\.git$||')
      GITHUB_REPO_API=$(echo "${GITHUB_REPO}" | sed 's|github\.com/|api.github.com/repos/|')
      GITHUB_PROJECT=$(curl -s ${GITHUB_REPO_API} | jq -r '.name')
      shift
      GITHUB_COMMIT=${1}
      shift

      git clone --filter=tree:0 --no-checkout --sparse ${GITHUB_REPO}
      cd ./${GITHUB_PROJECT}
      git reset --hard ${GITHUB_COMMIT}

      for SPARSE in ${@}; do
        git sparse-checkout add ${SPARSE}
      done

      eleven log info "github repo successfully sparse checkout"
    ;;

    "clone")
      GITHUB_REPO=$(echo "https://github.com/${1}" | sed 's|\.git$||')
      if [ -z ${2} ]; then
        git clone --recurse-submodules -j8 https://github.com/${GITHUB_REPO}
      else
        git clone --recurse-submodules -j8 https://github.com/${GITHUB_REPO} -b ${2}
      fi
    ;;

    *)
      eleven log warning "function ${FN} does not exist"
      exit 1
    ;;
  esac