#!/bin/sh
  FN=$(echo "${1}" | tr '[:upper:]' '[:lower:]')
  shift

  case "${FN}" in
    "build")
      # eleven go build /binary /go/src
      go mod tidy
      go build -ldflags="-extldflags=-static" -o ${1} ${2}
    ;;

    "patch")
      # eleven go patch google.golang.org/grpc v1.79.3 CVE-2026-33186
      # eleven go patch google.golang.org/grpc latest CVE-2026-33186
      if cat ./go.mod | grep -qE "${1} ${2}"; then
        exit 0
      else
        if [ "${2}" == "latest" ]; then
          LATEST=$(go list -m -f '{{.Version}}' "${1}@latest" 2>/dev/null)
          sed -i 's#'${1}' .\+[0-9]\+#'${1}' '${LATEST}'#g' ./go.mod
        else
          sed -i 's#'${1}' .\+[0-9]\+#'${1}' '${2}'#g' ./go.mod
        fi
        shift 2
        if [ $? ]; then
          for CVE in ${@}; do
            eleven log fix "CVE|${CVE}|${TARGETARCH:-amd64}"
          done
        fi
      fi
    ;;

    "upgrade")
      # eleven go upgrade
      go list -m -u all | awk '{print $1}' | xargs -n 1 go get -u
      go mod verify
    ;;

    *)
      eleven log warning "function ${FN} does not exist"
      exit 1
    ;;
  esac